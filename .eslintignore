# =============================================================================
# ESLint Ignore File — ZYNC Desktop Application
# =============================================================================
#
# This file specifies which files and directories should be completely
# ignored by ESLint. Unlike the ignorePatterns in .eslintrc.cjs, patterns
# in this file apply globally and cannot be overridden by inline comments
# or configuration overrides.
#
# =============================================================================

# ---------------------------------------------------------------------------
# Build Outputs
# ---------------------------------------------------------------------------
#
# These directories contain compiled/bundled code that should not be linted.
# They are generated by the build tools and will be overwritten on each build.
#

# Vite build output for the frontend
dist/

# Electron Builder output (packaged application)
dist_electron/

# TypeScript compilation output for Electron
dist-electron/

# Build resources (icons, etc.)
build/

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
#
# Third-party code should not be linted as we don't control it.
#

# npm/yarn dependency directory
node_modules/

# ---------------------------------------------------------------------------
# Generated Files
# ---------------------------------------------------------------------------
#
# Files that are auto-generated should not be linted.
#

# Package lock file (auto-generated by npm)
package-lock.json

# Minified files
*.min.js
*.min.css

# Source maps
*.map

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
#
# The backend has its own ESLint configuration and should not be
# processed by the frontend ESLint config.
#

backend/

# ---------------------------------------------------------------------------
# Test Coverage
# ---------------------------------------------------------------------------
#
# Test coverage reports are generated files that should not be linted.
#

coverage/

# ---------------------------------------------------------------------------
# Vite Cache
# ---------------------------------------------------------------------------
#
# Vite's internal cache directory.
#

.vite/

# ---------------------------------------------------------------------------
# Environment Files
# ---------------------------------------------------------------------------
#
# Environment files are not JavaScript/TypeScript and should not be linted.
#

.env
.env.*

# ---------------------------------------------------------------------------
# IDE and Editor Files
# ---------------------------------------------------------------------------
#
# IDE-specific configuration files should not be linted.
#

.vscode/
.idea/
