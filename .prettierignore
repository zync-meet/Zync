# =============================================================================
# Prettier Ignore File — ZYNC Desktop Application
# =============================================================================
#
# This file tells Prettier which files and directories to skip when
# formatting. Files listed here will not be modified by Prettier, even
# when running `prettier --write .` on the entire project.
#
# =============================================================================

# ---------------------------------------------------------------------------
# Build Outputs
# ---------------------------------------------------------------------------
#
# Compiled and bundled code should not be formatted as it will be
# overwritten on the next build.
#

# Vite build output directory
dist/

# Electron Builder packaged application output
dist_electron/

# TypeScript compilation output for Electron main process
dist-electron/

# Build resources (icons, installer assets)
build/

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
#
# Third-party code from npm packages should never be formatted.
#

# npm dependency directory
node_modules/

# ---------------------------------------------------------------------------
# Lock Files
# ---------------------------------------------------------------------------
#
# Lock files are auto-generated by package managers and should not be
# formatted. Formatting them can cause merge conflicts and invalidate
# the integrity hashes.
#

# npm lock file
package-lock.json

# yarn lock file (if switching to yarn in the future)
yarn.lock

# pnpm lock file (if switching to pnpm in the future)
pnpm-lock.yaml

# ---------------------------------------------------------------------------
# Generated/Minified Files
# ---------------------------------------------------------------------------
#
# Auto-generated and minified files should not be formatted.
#

# Minified JavaScript
*.min.js

# Minified CSS
*.min.css

# Source maps
*.map

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
#
# The backend directory may have its own formatting configuration.
#

backend/

# ---------------------------------------------------------------------------
# Coverage Reports
# ---------------------------------------------------------------------------
#
# Test coverage output files should not be formatted.
#

coverage/

# ---------------------------------------------------------------------------
# Cache Directories
# ---------------------------------------------------------------------------
#
# Various cache directories used by build tools.
#

.vite/
.eslintcache

# ---------------------------------------------------------------------------
# Environment Files
# ---------------------------------------------------------------------------
#
# Environment files have their own format and should not be modified.
#

.env
.env.*

# ---------------------------------------------------------------------------
# Changelog and Auto-generated Docs
# ---------------------------------------------------------------------------
#
# Some documentation files are auto-generated and should not be formatted.
#

CHANGELOG.md
